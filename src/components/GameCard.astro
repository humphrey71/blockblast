---
import type { Game } from '../types';

/**
 * Game thumbnail card. Image fills the card; a bottom darkening gradient keeps
 * the white "Hot" badge and hover title legible. Hover reveals the title + rating.
 *
 * Width is controlled by the parent (grid cell or fixed w-40); height follows the
 * 184x112 thumbnail aspect ratio, matching the live 160x96 cards at any width.
 *
 * Ported 1:1 from $SRC/src/components/GameCard.tsx (Next.js Link + next/image fill
 * → plain <a> + <img class="h-full w-full object-cover">). href pattern preserved
 * from source: `/${slug}`.
 */
interface Props {
  game: Game;
  class?: string;
}
const { game, class: className = '' } = Astro.props;

const HOT_BADGE_SRC = '/themes/block-blast.io/rs/imgs/svg/hot-badge.svg';
---

<a
  href={`/${game.slug}`}
  class:list={[
    'group relative block aspect-[184/112] overflow-hidden rounded-lg transition-transform duration-150 ease-in-out hover:z-10 hover:scale-[1.03]',
    className,
  ]}
>
  <img src={game.image} alt={game.title} class="h-full w-full object-cover" loading="lazy" />

  {/* Bottom darkening gradient (matches --gradient-card) */}
  <div
    class="pointer-events-none absolute inset-0 rounded-lg"
    style="background: var(--bb-grad-card);"
  />

  {/* Hover description: title + rating, fades in at bottom */}
  <div
    class="absolute inset-x-0 bottom-0 flex items-end gap-1 p-2 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
  >
    <span class="line-clamp-2 text-[13px] font-bold leading-tight text-white drop-shadow">
      {game.title}
    </span>
  </div>

  {/* "Hot" badge — asymmetric radius, sharp bottom-left corner */}
  {game.hot !== false && (
    <div class="absolute bottom-1.5 left-1.5">
      <span
        class="flex items-center gap-1 bg-gradient-to-r from-pink-500 to-fuchsia-600 px-[7px] py-[5px] text-white shadow-[6px_2px_12px_rgba(67,61,77,0.45)]"
        style="border-radius: 24px 32px 32px 4px; background-image: var(--bb-grad-pink);"
      >
        <span class="text-[12px] font-black leading-none tracking-[0.3px]">Hot</span>
        <img src={HOT_BADGE_SRC} alt="" class="h-3 w-3" />
      </span>
    </div>
  )}
</a>
