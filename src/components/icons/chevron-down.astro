---
/**
 * Lucide icon "chevron-down" (24x24, stroke=currentColor).
 * Used by Comments.astro sort <select> overlay; mirrors lucide-react's
 * ChevronDown used by $SRC/src/components/Comments.tsx.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<svg
  class={className}
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="m6 9 6 6 6-6"></path>
</svg>
