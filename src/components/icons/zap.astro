---
/**
 * Lucide icon "zap" (24x24, stroke=currentColor).
 * Rendered by NavRail.astro via the ICONS map; mirrors lucide-react's
 * Home/History/Shuffle/... used by $SRC/src/components/NavRail.tsx.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<svg
  class={className}
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  xmlns="http://www.w3.org/2000/svg"
>
<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
</svg>
