---
/**
 * Lucide icon "grid-2x2" (24x24, stroke=currentColor).
 * Rendered by NavRail.astro via the ICONS map; mirrors lucide-react's
 * Home/History/Shuffle/... used by $SRC/src/components/NavRail.tsx.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<svg
  class={className}
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  xmlns="http://www.w3.org/2000/svg"
>
<rect width="18" height="18" x="3" y="3" rx="2" />
  <path d="M3 12h18" />
  <path d="M12 3v18" />
</svg>
